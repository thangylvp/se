/data/
/dataset/
/datasets/
*.wav
*.flac
*.mp3
*.npy
*.npz

# ---- caches ----
.cache/
~/.cache/
hf_cache/
**/__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- python envs / packaging ----
.venv/
venv/
env/
*.egg-info/
build/
dist/
.python-version

