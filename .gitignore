# ---- secrets / env ----
.env
.env.*
!.env.example
*.pem

# ---- experiment outputs / artifacts (large, regenerable) ----
runs/
out/
outputs/
logs/
wandb/
tensorboard/
lightning_logs/
*.tar
*.ckpt
*.pt
*.pth
*.onnx
*.safetensors

# ...but DO track the released "model D" checkpoint used for the WER report
!checkpoints/
!checkpoints/model_D.tar

# ---- data / models (live in ../dataset, ../ckpt; never commit) ----
